<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — SecureBank</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-card { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 40px; width: 400px; }
    h1 { color: #38bdf8; font-size: 24px; margin-bottom: 8px; text-align: center; }
    .subtitle { color: #64748b; text-align: center; margin-bottom: 24px; font-size: 14px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; color: #94a3b8; font-size: 13px; margin-bottom: 4px; }
    .form-group input { width: 100%; padding: 10px 14px; border: 1px solid #334155; border-radius: 8px; background: #0f172a; color: #e2e8f0; font-size: 14px; }
    .form-group input:focus { outline: none; border-color: #38bdf8; }
    button { width: 100%; padding: 12px; border: none; border-radius: 8px; font-size: 14px; font-weight: bold; cursor: pointer; background: #0ea5e9; color: white; margin-top: 8px; }
    button:hover { background: #0284c7; }
    .error { background: #4c1d2e; border: 1px solid #ef4444; color: #fca5a5; padding: 10px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; text-align: center; }
    .hint { background: #1a2332; border: 1px solid #334155; border-radius: 8px; padding: 12px; margin-top: 20px; font-size: 12px; color: #64748b; }
    .hint code { background: #334155; padding: 2px 6px; border-radius: 4px; color: #fbbf24; }
  </style>
</head>
<body>
  <div class="login-card">
    <h1>🏦 SecureBank</h1>
    <p class="subtitle">Project 4: CSRF Attack & Defense</p>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="alice" autofocus />
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="password123" />
      </div>
      <button type="submit">Login</button>
    </form>

    <div class="hint">
      <strong>Test accounts:</strong><br>
      <code>alice</code> / <code>password123</code> (balance: $10,000)<br>
      <code>bob</code> / <code>password456</code> (balance: $5,000)
    </div>
  </div>
</body>
</html>
