<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DOM XSS Demo — SecureBlog</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; }
    .navbar { background: #1e293b; padding: 16px 40px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #334155; }
    .navbar h1 { color: #38bdf8; font-size: 20px; }
    .navbar a { color: #94a3b8; text-decoration: none; margin-left: 20px; font-size: 14px; }
    .navbar a:hover { color: #38bdf8; }
    .safe-toggle form { display: inline; }
    .safe-toggle button { padding: 6px 14px; border: none; border-radius: 6px; font-size: 13px; cursor: pointer; font-weight: bold; }
    .safe-on { background: #22c55e; color: white; }
    .safe-off { background: #ef4444; color: white; }
    .container { max-width: 900px; margin: 0 auto; padding: 30px 40px; }
    code { background: #334155; padding: 2px 6px; border-radius: 4px; font-size: 13px; color: #fbbf24; }
    .concept-box { background: #1e293b; border-left: 3px solid #fbbf24; padding: 16px 20px; margin: 16px 0; border-radius: 0 8px 8px 0; }
    .concept-box h3 { color: #fbbf24; font-size: 14px; margin-bottom: 6px; }
    .concept-box p { color: #94a3b8; font-size: 13px; line-height: 1.5; }
    button { padding: 10px 20px; border: none; border-radius: 8px; font-size: 14px; cursor: pointer; margin-right: 8px; margin-bottom: 8px; }
    .btn-primary { background: #0ea5e9; color: white; }
    .btn-danger { background: #ef4444; color: white; }
    .btn-safe { background: #22c55e; color: white; }
    .tag-xss { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; background: #f59e0b20; color: #fcd34d; border: 1px solid #f59e0b; }
    .result-box { padding: 14px; border-radius: 8px; margin: 12px 0; font-family: monospace; font-size: 13px; }
    .result-safe { background: #064e3b; border: 1px solid #059669; color: #6ee7b7; }
    .result-danger { background: #4c1d2e; border: 1px solid #ef4444; color: #fca5a5; }
    .result-info { background: #1e293b; border: 1px solid #38bdf8; color: #93c5fd; }
    .demo-area { background: #1e293b; border: 2px solid #f59e0b; border-radius: 12px; padding: 24px; margin: 20px 0; }
    .output-box { background: #0f172a; border: 1px solid #334155; border-radius: 8px; padding: 16px; margin: 12px 0; min-height: 60px; font-size: 15px; }
    .form-group { margin-bottom: 12px; }
    .form-group label { display: block; color: #94a3b8; font-size: 13px; margin-bottom: 4px; }
    .form-group input { width: 100%; padding: 10px; border: 1px solid #334155; border-radius: 8px; background: #0f172a; color: #e2e8f0; font-size: 14px; }
    .form-group input:focus { outline: none; border-color: #38bdf8; }
    .footer { margin-top: 40px; padding: 20px 40px; border-top: 1px solid #334155; color: #64748b; font-size: 13px; text-align: center; }
  </style>
</head>
<body>
  <nav class="navbar">
    <div style="display: flex; align-items: center; gap: 20px;">
      <h1>🛡️ SecureBlog</h1>
      <a href="/">Home</a>
      <a href="/search">Search</a>
      <a href="/dom-xss">DOM XSS</a>
      <a href="/playground">⚔️ Playground</a>
    </div>
    <div class="safe-toggle">
      <form action="/toggle-safe-mode" method="POST">
        <button class="<%= safeMode ? 'safe-on' : 'safe-off' %>">
          <%= safeMode ? '🛡️ SAFE' : '🔴 UNSAFE' %>
        </button>
      </form>
    </div>
  </nav>

  <div class="container">
    <h2 style="color: #38bdf8; margin-bottom: 8px;">
      🧩 DOM-Based XSS <span class="tag-xss">DOM XSS</span>
    </h2>
    <p style="color: #94a3b8; margin-bottom: 20px;">
      This type of XSS is entirely <strong>client-side</strong>. The server never sees the malicious payload —
      JavaScript reads from the URL and writes it directly into the page.
    </p>

    <% if (!safeMode) { %>
      <div class="result-box result-danger">
        🔴 UNSAFE: Using <code>innerHTML</code> to render user input from URL hash
      </div>
    <% } else { %>
      <div class="result-box result-safe">
        🛡️ SAFE: Using <code>textContent</code> instead of <code>innerHTML</code>
      </div>
    <% } %>

    <!-- ============================================ -->
    <!-- DOM XSS DEMO AREA                            -->
    <!-- ============================================ -->
    <div class="demo-area">
      <h3 style="color: #f59e0b; margin-bottom: 12px;">📝 Greeting Card Generator</h3>
      <p style="color: #94a3b8; font-size: 14px; margin-bottom: 16px;">
        Type a name below or put it in the URL hash. The page reads <code>location.hash</code>
        and renders it on the page.
      </p>

      <div class="form-group">
        <label>Enter a name (or use URL hash like <code>#YourName</code>)</label>
        <input type="text" id="name-input" placeholder="e.g., Mohit" />
      </div>

      <button class="btn-primary" onclick="renderGreeting()">Generate Greeting</button>
      <button class="btn-danger" onclick="injectXSS()">💉 Inject XSS Payload</button>
      <button class="btn-safe" onclick="clearOutput()">Clear</button>

      <div style="margin-top: 16px;">
        <p style="color: #64748b; font-size: 12px;">Output:</p>
        <div class="output-box" id="greeting-output">
          Enter a name above to see the greeting...
        </div>
      </div>

      <div style="margin-top: 12px;">
        <p style="color: #64748b; font-size: 12px;">How the code renders it (<%= safeMode ? 'SAFE' : 'UNSAFE' %>):</p>
        <div class="result-box" style="background: #0f172a; border-color: #334155; color: #94a3b8;">
          <% if (!safeMode) { %>
            <code style="color: #ef4444;">element.innerHTML = "Hello, " + userInput + "!"</code>
            <br><span style="color: #ef4444;">← Dangerous! Browser parses HTML tags in the input</span>
          <% } else { %>
            <code style="color: #22c55e;">element.textContent = "Hello, " + userInput + "!"</code>
            <br><span style="color: #22c55e;">← Safe! Browser treats everything as plain text</span>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- HASH READER (auto-reads from URL)            -->
    <!-- ============================================ -->
    <div class="demo-area" style="border-color: #ef4444;">
      <h3 style="color: #ef4444; margin-bottom: 12px;">🔗 URL Hash Reader (Auto-Runs)</h3>
      <p style="color: #94a3b8; font-size: 14px; margin-bottom: 16px;">
        This section automatically reads <code>location.hash</code> and renders it.
        Try adding <code>#&lt;img src=x onerror=alert('DOM XSS!')&gt;</code> to the URL.
      </p>

      <p style="color: #64748b; font-size: 12px;">Current URL hash:</p>
      <div class="result-box" style="background: #0f172a; border-color: #334155;">
        <span id="current-hash" style="color: #fbbf24;">Loading...</span>
      </div>

      <p style="color: #64748b; font-size: 12px;">Rendered output:</p>
      <div class="output-box" id="hash-output">
        Reading from URL hash...
      </div>

      <div style="margin-top: 12px;">
        <button class="btn-danger" onclick="setMaliciousHash()">Set Malicious Hash</button>
        <button class="btn-safe" onclick="setSafeHash()">Set Safe Hash</button>
      </div>
    </div>

    <div class="concept-box">
      <h3>🟡 DOM-Based XSS — How it works</h3>
      <p>
        Unlike Reflected/Stored XSS, the <strong>server never sees the payload</strong>.<br>
        JavaScript in the page reads from an untrusted source (URL, <code>location.hash</code>, <code>document.referrer</code>)<br>
        and writes it into the DOM using a dangerous "sink" like <code>innerHTML</code>.<br><br>

        <strong>Source → Sink chain:</strong><br>
        📥 Sources (attacker-controlled input): <code>location.hash</code>, <code>location.search</code>, <code>document.URL</code>, <code>document.referrer</code><br>
        📤 Sinks (dangerous output methods): <code>innerHTML</code>, <code>outerHTML</code>, <code>document.write()</code>, <code>eval()</code><br><br>

        <strong>Why WAFs can't detect this:</strong><br>
        The malicious payload is in the URL fragment (<code>#...</code>) which is <strong>never sent to the server</strong>!<br>
        The browser processes everything client-side.<br><br>

        <strong>Defense:</strong><br>
        1. Use <code>textContent</code> instead of <code>innerHTML</code><br>
        2. Use <code>setAttribute()</code> instead of direct attribute assignment<br>
        3. Sanitize with DOMPurify if you need HTML rendering<br>
        4. Never use <code>eval()</code>, <code>document.write()</code>, or <code>setTimeout(string)</code>
      </p>
    </div>
  </div>

  <div class="footer">
    🛡️ Project 3: XSS Attack & Defense
  </div>

  <script>
    const safeMode = <%= safeMode ? 'true' : 'false' %>;

    // ---- GREETING GENERATOR ----
    function renderGreeting() {
      const input = document.getElementById('name-input').value;
      const output = document.getElementById('greeting-output');

      if (!safeMode) {
        // 🔴 UNSAFE: innerHTML — browser parses HTML tags!
        output.innerHTML = '<h2 style="color: #38bdf8;">Hello, ' + input + '! 👋</h2>';
      } else {
        // 🛡️ SAFE: textContent — treats everything as plain text
        output.textContent = 'Hello, ' + input + '! 👋';
      }
    }

    function injectXSS() {
      document.getElementById('name-input').value = '<img src=x onerror=alert("DOM XSS via innerHTML!")>';
      renderGreeting();
    }

    function clearOutput() {
      document.getElementById('greeting-output').textContent = 'Enter a name above to see the greeting...';
      document.getElementById('name-input').value = '';
    }

    // ---- URL HASH READER (auto-runs) ----
    function readHash() {
      const hash = decodeURIComponent(location.hash.substring(1)); // Remove the #
      const hashDisplay = document.getElementById('current-hash');
      const hashOutput = document.getElementById('hash-output');

      hashDisplay.textContent = location.hash || '(empty — add #something to the URL)';

      if (hash) {
        if (!safeMode) {
          // 🔴 UNSAFE: innerHTML with user-controlled input!
          hashOutput.innerHTML = '<p style="font-size: 18px;">Welcome, ' + hash + '!</p>';
        } else {
          // 🛡️ SAFE: textContent
          hashOutput.textContent = 'Welcome, ' + hash + '!';
        }
      } else {
        hashOutput.textContent = 'Add a #name to the URL to see it rendered here.';
      }
    }

    function setMaliciousHash() {
      location.hash = '<img src=x onerror=alert("DOM XSS via location.hash!")>';
    }

    function setSafeHash() {
      location.hash = 'Mohit';
    }

    // Run on page load AND when hash changes
    readHash();
    window.addEventListener('hashchange', readHash);
  </script>
</body>
</html>
